# Uygulama
PORT=3000
APP_NAME=Avukatım
SUPPORT_EMAIL=

# Prod'da domain sabitlemek istersen (Host header injection riskini azaltır)
# ALLOWED_HOSTS=example.com,www.example.com
ALLOWED_HOSTS=

# HTTPS yönlendirme (domainin HTTPS olduktan sonra aç)
FORCE_HTTPS=false

# HSTS (yalnızca HTTPS üzerinde anlamlı). Prod HTTPS stabil olduktan sonra aç.
HSTS=false
HSTS_PRELOAD=false
HSTS_MAX_AGE=31536000

# Dosya/metin sınırları
UPLOAD_MAX_MB=10
MAX_TEXT_CHARS=140000

# OCR (opsiyonel)
ENABLE_OCR=false
OCR_MIN_TEXT_CHARS=220
OCR_LANG=tur+eng
OCR_STEP_TIMEOUT_MS=25000
# Windows örnek:
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
# PDFTOPPM_CMD=C:\poppler\Library\bin\pdftoppm.exe
TESSERACT_CMD=
PDFTOPPM_CMD=

# Paywall (PDF rapor indirme için anahtar)
PAYWALL_MODE=off
PREMIUM_KEY=

# Kredi sistemi (analiz hakkı)
BILLING_MODE=credits
FREE_TRIAL_ANALYSES=1

# Elle kredi kodları (opsiyonel)
# JSON: [{"code":"AVUKATIM10","credits":10}]
# veya CSV: AVUKATIM10:10,AVUKATIM25:25
CREDIT_CODES=
UNLIMITED_KEY=

# Ödeme
# PAYMENTS_PROVIDER=lemonsqueezy | iyzico | off
PAYMENTS_PROVIDER=lemonsqueezy

# --- iyzico (Checkout Form) ---
# Not: iyzico callback URL sunucuna dışarıdan erişebilmeli.
# Local test için ngrok kullanıp APP_BASE_URL ayarlayabilirsin.
IYZICO_ENV=sandbox
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
# İstersen override: https://sandbox-api.iyzipay.com veya https://api.iyzipay.com
IYZICO_URI=
# Prod için şart: https://senin-domainin.com
APP_BASE_URL=

# Kredi paketleri (iyzico) — JSON array
# Örn:
# IYZICO_PACKS=[
#   {"label":"1 Kredi • 49₺","credits":1,"price":49,"currency":"TRY"},
#   {"label":"5 Kredi • 149₺","credits":5,"price":149,"currency":"TRY"},
#   {"label":"10 Kredi • 249₺","credits":10,"price":249,"currency":"TRY"},
#   {"label":"20 Kredi • 399₺","credits":20,"price":399,"currency":"TRY"}
# ]
IYZICO_PACKS=[]

# --- Lemon Squeezy ---

# Kredi paketleri (butonlar) — JSON array
# Örn:
# LS_CHECKOUT_PACKS=[
#   {"label":"1 Kredi","credits":1,"url":"https://..."},
#   {"label":"5 Kredi","credits":5,"url":"https://..."},
#   {"label":"10 Kredi","credits":10,"url":"https://..."},
#   {"label":"20 Kredi","credits":20,"url":"https://..."}
# ]
LS_CHECKOUT_PACKS=[]

# Variant-ID -> kredi eşlemesi (custom_data gelmezse fallback)
LS_VARIANT_CREDITS={}

# Webhook imza sırrı
LEMONSQUEEZY_WEBHOOK_SECRET=

# Rate limit (genel /api)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30

# Daha agresif: /api/analyze-file (upload) rate limit
RATE_LIMIT_ANALYZE_FILE_WINDOW_MS=600000
RATE_LIMIT_ANALYZE_FILE_MAX=20

# /api/iyzico/initiate rate limit
RATE_LIMIT_IYZICO_WINDOW_MS=600000
RATE_LIMIT_IYZICO_MAX=10

# Opsiyonel antivirüs taraması (upload)
# Varsayılan: off
ANTIVIRUS_MODE=off
# ANTIVIRUS_MODE=clamav
CLAMAV_BIN=
ANTIVIRUS_TIMEOUT_MS=20000
ANTIVIRUS_MAX_SCAN_MB=15
ANTIVIRUS_FAIL_OPEN=false

# Anti-abuse: ağır işlerde concurrency (DoS dayanımı)
HEAVY_TASK_CONCURRENCY=2
HEAVY_TASK_QUEUE_MAX=40
HEAVY_TASK_QUEUE_WAIT_MS=20000

# Anti-abuse: /api/analyze-file için ek "slowdown" (rate-limit'e ek olarak)
SLOWDOWN_ANALYZE_FILE_WINDOW_MS=600000
SLOWDOWN_ANALYZE_FILE_AFTER=6
SLOWDOWN_ANALYZE_FILE_DELAY_MS=400
SLOWDOWN_ANALYZE_FILE_MAX_MS=5000

# Anti-bruteforce: redeem/restore/report/callback limitleri
RATE_LIMIT_REDEEM_WINDOW_MS=600000
RATE_LIMIT_REDEEM_MAX=20

RATE_LIMIT_RESTORE_WINDOW_MS=600000
RATE_LIMIT_RESTORE_MAX=30

RATE_LIMIT_REPORT_WINDOW_MS=600000
RATE_LIMIT_REPORT_MAX=30

RATE_LIMIT_IYZICO_CALLBACK_WINDOW_MS=600000
RATE_LIMIT_IYZICO_CALLBACK_MAX=60

# Sunucu timeout (DoS dayanımı)
SERVER_REQUEST_TIMEOUT_MS=60000
SERVER_HEADERS_TIMEOUT_MS=65000
SERVER_KEEPALIVE_TIMEOUT_MS=5000

# Ağır dosya parsing'i worker thread'de çalıştır (event-loop bloklanmasın)
EXTRACT_USE_WORKER=true
EXTRACT_TIMEOUT_MS=15000

# --- Ek güvenlik: anti-abuse ban (in-memory) ---
# Rate-limit'e giren / şüpheli davranan IP'leri geçici banlar.
ABUSE_SHIELD=true
ABUSE_STRIKE_THRESHOLD=3
ABUSE_STRIKE_DECAY_MIN=60
ABUSE_BAN_BASE_MIN=10
ABUSE_BAN_MAX_MIN=1440
ABUSE_BAN_STRIKES_MULTIPLIER=2

# --- Ek güvenlik: DOCX (ZIP) bomb guard ---
# DOCX aslında ZIP olduğu için, merkezi dizinden toplam açılan boyut/entry sayısı kontrol edilir.
ZIP_MAX_ENTRIES=2500
ZIP_MAX_UNCOMPRESSED_MB=60
ZIP_MAX_RATIO=250
