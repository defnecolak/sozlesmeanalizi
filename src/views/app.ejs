<!doctype html>
<html lang="tr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title><%= appName %></title>
  <meta name="description" content="Sözleşme yükle, risk sinyallerini gör, PDF rapor indir." />
  <meta property="og:title" content="<%= appName %>" />
  <meta property="og:description" content="Sözleşme yükle, riskleri gör, pazarlık metni ve PDF rapor al." />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="<%= baseUrl %>/uygulama" />
  <meta property="og:image" content="<%= baseUrl %>/public/assets/logo.png" />
  <link rel="canonical" href="<%= baseUrl %>/uygulama" />
  <link rel="icon" href="/public/assets/icon.svg" type="image/svg+xml" />
  <link rel="icon" href="/public/assets/icon.png" type="image/png" />
  <link rel="manifest" href="/manifest.webmanifest" />
  <meta name="theme-color" content="#0b1020" />
  <script nonce="<%= cspNonce %>">
  (function(){
    try{
      var k='avukatim_theme';
      var t=localStorage.getItem(k);
      if(t!=='light' && t!=='dark'){
        t = (window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches) ?'light':'dark';
      }
      document.documentElement.setAttribute('data-theme', t);
    }catch(e){}
  })();
</script>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="/public/styles.css?v=43" />
<script src="/public/theme.js?v=40" defer></script>
</head>
<body>
  <header class="topnav">
    <div class="topnav-inner">
        <!-- / ana sayfa bazı kullanıcıları "under construction" sayfasına götürebiliyor.
             Uygulama içinde kalmak için logoyu /uygulama'ya yönlendiriyoruz. -->
        <a class="topnav-brand" href="/uygulama">
        <img class="topnav-icon" src="/public/assets/icon.svg" alt="" />
        <span class="topnav-name"><%= appName %></span>
      </a>
      <nav class="topnav-links">
        <a href="/uygulama">Uygulama</a>
        <a href="/fiyatlandirma">Fiyatlandırma</a>
        <a href="/sss">SSS</a>
      </nav>
      <div class="topnav-actions">
        <% if (billingMode === "credits") { %>
          <div class="credits-pill hidden" id="creditsPill" title="Kalan analiz kredin">Kredi: <span id="creditsCount">—</span></div>
        <% } %>
        <button class="iconbtn" id="themeToggle" type="button" aria-label="Tema değiştir" title="Koyu/Açık tema"></button>
        <button class="btn tiny hide-mobile" id="btnDemo" type="button">Demo</button>
        <button class="btn tiny hide-mobile" id="btnReset" type="button">Sıfırla</button>
        <button class="iconbtn mobile-menu-btn" id="mobileMenuBtn" type="button" aria-label="Menü" title="Menü">☰</button>
      </div>
    </div>
    <!-- Mobil menü paneli -->
    <div class="mobile-menu hidden" id="mobileMenu">
      <nav class="mobile-menu-links">
        <a href="/uygulama">Uygulama</a>
        <a href="/fiyatlandirma">Fiyatlandırma</a>
        <a href="/sss">SSS</a>
      </nav>
      <div class="mobile-menu-actions">
        <button class="btn tiny" id="btnDemoMobile" type="button">Demo</button>
        <button class="btn tiny" id="btnResetMobile" type="button">Sıfırla</button>
      </div>
    </div>
  </header>

  <div class="container">
    <div class="pagehead">
      <div>
        <h1>Sözleşme Analizi <span class="muted small appver">v<%= version %></span></h1>
        <div class="muted">Dosya yükle • risk sinyallerini gör • PDF rapor indir</div>
      </div>
    </div>
    <div id="toast" class="toast hidden" role="status" aria-live="polite"></div>
<div class="card">
      <div class="warnbox">
        <strong>Uyarı:</strong> Bu araç hukuk danışmanlığı değildir. Son karar için avukata danışın.
      </div>

      <div class="grid3">
        <label class="label">
          Rol (bakış açısını etkiler)
          <select id="role" class="select">
            <% roles.forEach(r => { %>
              <option value="<%= r.id %>"><%= r.label %></option>
            <% }) %>
          </select>
          <div class="muted small fieldhint" id="roleHelp"><%= appMeta.roleHelpers?.genel || "" %></div>
        </label>

        <label class="label">
          Sözleşme Türü
          <select id="pack" class="select">
            <% packOptions.forEach(p => { %>
              <option value="<%= p.id %>"><%= p.label %></option>
            <% }) %>
          </select>
          <div class="muted small fieldhint" id="packHelp"><%= appMeta.packHelpers?.genel || "" %></div>
          <div class="muted small fieldhint" id="packExamples">Örnekler: <%= (appMeta.packExamples?.genel || []).join(", ") %></div>
        </label>

        <label class="label">
          Analiz Hassasiyeti
          <select id="sensitivity" class="select">
            <% (sensitivityOptions || []).forEach(s => { %>
              <option value="<%= s.id %>" <%= s.id === "dengeli" ? "selected" : "" %>><%= s.label %></option>
            <% }) %>
          </select>
          <div class="muted small fieldhint" id="sensitivityHelp"><%= appMeta.sensitivityHelpers?.dengeli || "" %></div>
        </label>

        <label class="label">
          Sözleşme Dosyası (PDF/DOCX/TXT)
          <input type="file" id="file" accept=".pdf,.docx,.txt,application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,text/plain" />
          <div class="muted small">Maksimum dosya boyutu: <%= maxFileMb %> MB</div>
        </label>
      </div>

      <div class="row">
        <div class="muted small" id="fileInfo">Dosya seçilmedi.</div>
        <div class="muted small" id="billingInfo"></div>
        <div class="spacer"></div>
        <button class="btn primary" id="btnAnalyze" disabled>Analiz Et</button>
      <% if (billingMode === "credits") { %>
<div class="billing-box">
  <div class="billing-left">
    <div class="muted small"><strong><%= freeTrial %></strong> ücretsiz analiz sonrası kredi gerekir.</div>
    <% if ((paymentsProvider === "lemonsqueezy" || paymentsProvider === "iyzico") && checkoutPacks && checkoutPacks.length) { %>
      <div class="packs">
        <% checkoutPacks.forEach(p => { %>
          <button class="btn" data-checkout-pack data-credits="<%= p.credits %>"><%= p.label %></button>
        <% }) %>
      </div>
      <% if (paymentsProvider === "iyzico") { %>
      <div class="payment-logos">
        <span class="pay-logo-iyzico">iyzico</span>
        <span class="pay-logo-sep">ile öde</span>
        <span class="pay-logo-divider"></span>
        <svg class="pay-logo pay-logo-visa" viewBox="0 0 58 20" xmlns="http://www.w3.org/2000/svg"><path d="M23.6 1.3L15.9 18.7h-5.4L6.7 5c-.2-.9-.4-1.2-1.1-1.6C4.4 2.7 2.5 2.2.8 1.8l.1-.5h8.8c1.1 0 2.1.7 2.3 2l2.1 11 5.4-13h4.1zm18.6 11.6c0-4.8-6.6-5-6.6-7.2 0-.6.6-1.3 1.9-1.5.7-.1 2.4-.1 4.4.8l.8-3.4C41.7 1.3 40.3.9 38.6.9c-3.9 0-6.6 2.1-6.7 5 0 2.2 2 3.4 3.5 4.2 1.5.8 2.1 1.2 2.1 1.9 0 1-1.2 1.5-2.3 1.5-2.3 0-3.6-.6-4.6-1.1l-.8 3.5c1.1.5 3 .9 5 .9 4.1 0 6.8-2.1 7.4-3.9zm11.7 5.8h3.6L54.3 1.3h-4c-1 0-1.8.5-2.1 1.4l-6 16.1h4.1l.8-2.3h5.1l.7 2.3zM48.3 13.4l2.1-6 1.3 6h-3.4zM30.4 1.3L27.2 18.7h-4l3.2-17.4h4z" fill="#1A1F71"/></svg>
        <svg class="pay-logo pay-logo-mc" viewBox="0 0 40 25" xmlns="http://www.w3.org/2000/svg"><circle cx="15" cy="12.5" r="9.5" fill="#EB001B"/><circle cx="25" cy="12.5" r="9.5" fill="#F79E1B"/><path d="M20 5.3a9.5 9.5 0 0 1 3.5 7.2 9.5 9.5 0 0 1-3.5 7.2 9.5 9.5 0 0 1-3.5-7.2A9.5 9.5 0 0 1 20 5.3z" fill="#FF5F00"/></svg>
      </div>
      <div class="muted small">Ödeme iyzico üzerinden yapılır. Ödeme tamamlandıktan sonra kredin otomatik yüklenir (bazı durumlarda 5-10 sn sürebilir).</div>
      <div class="muted small">Not: Ödeme için e-posta istenebilir (hesap açmana gerek yok).</div>
    <% } else { %>
      <div class="muted small">Ödeme sonrası kredin otomatik yüklenir (bazı durumlarda 5-10 sn sürebilir).</div>
    <% } %>
    <% } else if (checkoutUrl) { %>
      <a class="btn" href="<%= checkoutUrl %>" target="_blank" rel="noopener">Kredi Satın Al</a>
    <% } else { %>
      <div class="muted small">Satın alma linki için CHECKOUT_URL veya LS_CHECKOUT_PACKS ekleyebilirsin.</div>
    <% } %>
  </div>
  <div class="billing-right">
    <input class="input" id="redeemCode" placeholder="Kredi kodu (örn. AVUKATIM10)" />
    <button class="btn primary" id="btnRedeem">Kodu Aktif Et</button>
    <div class="muted small" style="margin-top:10px">Cihaz değiştirdiysen / çerezler silindiyse:</div>
    <div class="row" style="margin-top:6px; gap:8px; align-items:center">
      <input class="input" id="restoreCode" placeholder="Kurtarma kodu (örn. A8F3-6K2M-P9QD)" />
      <button class="btn" id="btnRestore">Krediyi Kurtar</button>
    </div>

    <div id="lastRestoreBox" class="last-restore hidden">
      <div class="muted small">Kurtarma kodun (sakla): <code id="lastRestoreCode"></code></div>
      <div class="row" style="margin-top:8px; gap:8px; align-items:center">
        <button class="btn tiny" id="btnCopyLastRestore" type="button">Kopyala</button>
        <button class="btn tiny" id="btnClearLastRestore" type="button">Temizle</button>
      </div>
      <div class="muted small" style="margin-top:8px">Bu kod, çerezler silinse bile kredini geri almak içindir. Hesap gerekmez.</div>
    </div>
  </div>
</div>
<% } %>

</div>

    <section class="card hidden" id="resultCard">
      <div class="result-top">
        <div>
          <h2>Sonuç</h2>
        </div>
        <div class="result-actions">
          <% if (paywallMode === "on") { %>
            <input class="input" id="premiumKey" placeholder="Premium anahtarı" />
          <% } %>
          <button class="btn" id="btnPdf" disabled>PDF Rapor İndir</button>
        </div>
      </div>

      <section class="correctness-box hidden" id="correctnessBox">
        <div class="correctness-head">
          <h3>Sözleşme Doğru mu?</h3>
          <span class="pill" id="correctnessBadge">—</span>
        </div>
        <div class="muted" id="correctnessText">—</div>
        <ul class="correctness-list" id="correctnessList"></ul>
      </section>

      <section class="correctness-box hidden" id="decisionBox">
        <div class="correctness-head">
          <h3>Karar Önerisi</h3>
          <span class="pill" id="decisionBadge">—</span>
        </div>
        <div class="muted" id="decisionText">—</div>
        <div class="plan-grid">
          <div>
            <div class="muted small plan-title">Neden?</div>
            <ul class="correctness-list" id="decisionReasons"></ul>
          </div>
          <div>
            <div class="muted small plan-title">Sonraki adım</div>
            <ul class="correctness-list" id="decisionNext"></ul>
          </div>
        </div>
      </section>

      <section class="correctness-box hidden" id="actionPlanBox">
        <div class="correctness-head">
          <h3>İmza Öncesi Plan</h3>
          <span class="pill" id="actionPlanBadge">—</span>
        </div>
        <div class="muted" id="actionPlanText">—</div>
        <div class="plan-grid">
          <div>
            <div class="muted small plan-title">Önce düzelt</div>
            <ul class="correctness-list" id="actionPlanMust"></ul>
          </div>
          <div>
            <div class="muted small plan-title">Netleştir</div>
            <ul class="correctness-list" id="actionPlanClarify"></ul>
          </div>
          <div>
            <div class="muted small plan-title">Dengeleyici sinyaller</div>
            <ul class="correctness-list" id="actionPlanGood"></ul>
          </div>
        </div>
      </section>

      <div class="score-grid">
        <div class="score-box">
          <div class="muted small" title="Bu skor, tespit edilen risk türleri ve şiddetine göre hesaplanan yaklaşık bir göstergedir.">Risk Skoru</div>
          <div class="score" id="riskScore">—</div>
          <div class="pill" id="riskLevel">—</div>
        </div>
        <div class="score-box">
          <div class="muted small">Risk Maddeleri</div>
          <div class="score" id="issueCount">—</div>
          <div class="muted small">Tespit edilen net madde sayısı</div>
        </div>
        <div class="score-box">
          <div class="muted small">Belirsizlik / Ek Uyarılar</div>
          <div class="score" id="softCount">—</div>
          <div class="muted small">Eksik/belirsiz alan sinyalleri</div>
        </div>
      </div>

      <!-- Skor Açıklaması kaldırıldı (tekrar eden içerik + daha sade UI) -->

      <div class="top3">
        <h3>En Önemli 3 Risk</h3>
        <div id="top3List" class="list"></div>
      </div>

      <div class="negotiation" id="negBox">
        <div class="neg-head">
          <h3>Karşı Tarafa Gönderilebilir Revize Metni</h3>
          <div class="muted small">Analizde çıkan riskleri, seçtiğin sözleşme türüne uygun daha doğal, profesyonel ve gönderilebilir bir revize metnine dönüştürür.</div>
        </div>
        <div class="row" style="gap:8px; align-items:center; flex-wrap:wrap">
          <button class="btn" id="btnNegBuild">Yeniden Yaz</button>
          <button class="btn" id="btnNegCopy" disabled>Kopyala</button>
          <button class="btn" id="btnNegClear">Temizle</button>
          <label class="muted small" style="display:flex; align-items:center; gap:8px; margin-left:auto">
            <input type="checkbox" id="negOnlyFiltered" />
            Sadece ekranda görünen (filtreli) riskleri kullan
          </label>
        </div>
        <textarea id="negText" class="textarea" rows="9" readonly placeholder="Analiz yaptıktan sonra burada, karşı tarafa doğrudan iletebileceğin temiz bir revize metni oluşur."></textarea>
        <div class="muted small">İpucu: Her risk kartındaki “Revize Metni” alanı tek madde için kısa bir taslak üretir; üstteki kutu ise tüm riskleri bir araya getirir.</div>
      </div>

      <section class="correctness-box hidden" id="redlineBox">
        <div class="correctness-head">
          <h3>Redline / Revize Önerileri</h3>
        </div>
        <div class="muted">Aşağıdaki maddeler için karşı tarafa doğrudan revize talebi gönderebilirsin.</div>
        <div class="redline-grid" id="redlineList"></div>
      </section>

      <section class="correctness-box hidden" id="whatIfBox">
        <div class="correctness-head">
          <h3>What-if / Olası Sonuçlar</h3>
        </div>
        <div class="muted">Sözleşme çalışmaya başladığında tipik senaryolarda sana nasıl dönebileceğini özetler.</div>
        <div class="redline-grid" id="whatIfList"></div>
      </section>

      <!-- İçerik İyileştirmeleri -->
      <section class="correctness-box hidden" id="executiveSummaryBox">
        <div class="correctness-head">
          <h3>Yönetici Özeti</h3>
          <span class="pill" id="execStatusBadge">—</span>
        </div>
        <div id="executiveSummaryContent"></div>
      </section>

      <section class="correctness-box hidden" id="ratioAnalysisBox">
        <div class="correctness-head">
          <h3>Oran Analizi</h3>
        </div>
        <div class="muted">Cezai şart, depozito, faiz gibi değerlerin sektör ortalamalarıyla karşılaştırması.</div>
        <div class="redline-grid" id="ratioAnalysisList"></div>
      </section>

      <section class="correctness-box hidden" id="sectorRedFlagsBox">
        <div class="correctness-head">
          <h3>Sektöre Özel Eksikler</h3>
        </div>
        <div class="muted">Seçtiğin sözleşme türüne özel, eksik veya belirsiz kalan alanlar.</div>
        <div class="redline-grid" id="sectorRedFlagsList"></div>
      </section>

      <section class="correctness-box hidden" id="comparativeStatsBox">
        <div class="correctness-head">
          <h3>Karşılaştırmalı Analiz</h3>
        </div>
        <div id="comparativeStatsContent"></div>
      </section>

      <section class="correctness-box hidden" id="rewriteSuggestionsBox">
        <div class="correctness-head">
          <h3>Somut Yeniden Yazım Önerileri</h3>
        </div>
        <div class="muted">Her risk maddesi için "mevcut (sorunlu)" ve "önerilen (dengeli)" madde karşılaştırması.</div>
        <div class="redline-grid" id="rewriteSuggestionsList"></div>
      </section>

      <section class="correctness-box hidden" id="powerBalanceBox">
        <div class="correctness-head">
          <h3>Güç Dengesi Analizi</h3>
          <span class="pill" id="powerBalanceBadge">—</span>
        </div>
        <div id="powerBalanceContent"></div>
        <div class="redline-grid" id="powerBalanceList"></div>
      </section>

      <section class="correctness-box hidden" id="negotiationPriorityBox">
        <div class="correctness-head">
          <h3>Müzakere Öncelik Sıralaması</h3>
        </div>
        <div class="muted">Hangi maddeyi önce müzakere etmen gerektiğini, etki ve kabul olasılığına göre sıralar.</div>
        <div id="negotiationPriorityContent"></div>
      </section>

      <section class="correctness-box hidden" id="missingClausesBox">
        <div class="correctness-head">
          <h3>Eksik Madde Tespiti</h3>
          <span class="pill" id="missingClausesBadge">—</span>
        </div>
        <div id="missingClausesContent"></div>
        <div class="redline-grid" id="missingClausesList"></div>
      </section>

      <section class="correctness-box hidden" id="timelineMapBox">
        <div class="correctness-head">
          <h3>Süre Haritası</h3>
        </div>
        <div class="muted">Sözleşmedeki tüm süre ve tarihleri tek bakışta gör.</div>
        <div id="timelineMapContent"></div>
      </section>

      <section class="correctness-box hidden" id="riskSummaryCardBox">
        <div class="correctness-head">
          <h3>Risk Özet Kartı</h3>
        </div>
        <div class="muted">Avukatına veya karşı tarafa gönderebileceğin tek sayfalık özet.</div>
        <div id="riskSummaryCardContent"></div>
        <div style="margin-top:12px;text-align:center">
          <button type="button" class="btn btn-secondary" id="btnCopyRiskCard" style="font-size:0.85em">Özeti Kopyala</button>
        </div>
      </section>

      <section class="correctness-box hidden" id="subscoresBox">
        <div class="correctness-head">
          <h3>Alt Skorlar</h3>
        </div>
        <div class="subscore-grid" id="subscoresGrid"></div>
      </section>

      <section class="correctness-box hidden" id="mitigationBox">
        <div class="correctness-head">
          <h3>Dengeleyici Maddeler</h3>
          <span class="pill" id="mitigationBadge">—</span>
        </div>
        <div class="muted" id="mitigationText">—</div>
        <ul class="correctness-list" id="mitigationList"></ul>
      </section>

      <div class="filters">
        <div class="filter-group">
          <div class="muted small">Seviye</div>
          <div class="chips" id="sevChips"></div>
        </div>
        <div class="filter-group">
          <div class="muted small">Kategori</div>
          <div class="chips" id="catChips"></div>
        </div>
      </div>

      <div class="split">
        <div>
          <h3>Riskler</h3>
          <div id="issueList" class="list"></div>

          <h3>Belirsizlik / Ek Uyarılar</h3>
          <div id="softList" class="list"></div>
        </div>

        <div class="history-col">
          <details class="history-details">
            <summary>Geçmiş (bu cihaz)</summary>
            <div class="muted small" style="margin-top:6px">Bu listede sadece bu cihazda yapılan son analizler görünür.</div>
            <div id="history" class="history"></div>
          </details>
        </div>
      </div>

      <section class="correctness-box hidden" id="marketBox">
        <div class="correctness-head">
          <h3>Piyasa / Mantık Kontrolü</h3>
          <span class="pill" id="marketBadge">—</span>
        </div>
        <div class="muted" id="marketText">—</div>
        <ul class="correctness-list" id="marketList"></ul>
        <div class="muted small" id="marketCaveats" style="margin-top:8px"></div>
      </section>

      <div class="simulator hidden" id="simCard">
        <h3 id="simTitle">Maliyet / Piyasa Kontrolü</h3>
        <div class="muted small" id="simSummary">—</div>

        <div class="sim-controls" id="simControls">
          <div>
            <div class="muted small">İptal: Davete kaç gün kala?</div>
            <input type="range" id="cancelDays" min="0" max="365" value="60" />
            <div class="muted small" id="cancelDaysVal">—</div>
          </div>

          <div>
            <div class="muted small">Gerçek kişi sayısı</div>
            <input class="input" id="actualGuests" type="number" min="0" step="1" />
            <input type="range" id="actualGuestsRange" min="0" max="600" value="300" />
            <div class="muted small" id="actualGuestsVal">—</div>
            <div class="muted small">Garanti kişi sayısını aşarsan ek maliyet doğabilir.</div>
          </div>
        </div>

        <div class="sim-boxes" id="simScenarioBoxes">
          <div class="sim-box">
            <div class="sim-title">İptal Senaryosu</div>
            <div id="cancelResult" class="sim-body">—</div>
          </div>
          <div class="sim-box">
            <div class="sim-title">Kişi Sayısı Senaryosu</div>
            <div id="guestResult" class="sim-body">—</div>
          </div>
        </div>

        <div class="muted small" id="simNote">
          Not: Bu bölüm sözleşmeden otomatik çıkarım yapar ve yaklaşık değerler üretir. Kesin rakamlar için sözleşme metnini ve yazışmaları esas alın.
        </div>
      </div>

      <div class="muted small footer-note">
        Bu çıktı bilgilendirme amaçlıdır; hukuki tavsiye değildir.
      </div>
    </section>

    <footer class="footer muted small">
      <a href="/">Ana Sayfa</a> • <a href="/fiyatlandirma">Fiyatlandırma</a> • <a href="/sss">SSS</a> • <a href="/iletisim">İletişim</a> • <a href="/sorumluluk">Sorumluluk Reddi</a> • <a href="/gizlilik">Gizlilik</a> • <a href="/kvkk">KVKK</a> • <a href="/kullanim-sartlari">Kullanım Şartları</a> • <a href="/iade">İade Politikası</a>
      <% if (supportEmail) { %>
        <span> • Destek: <a href="mailto:<%= supportEmail %>"><%= supportEmail %></a></span>
      <% } %>
    </footer>
  </div>



  <!-- iyzico ödeme modalı (PAYMENTS_PROVIDER=iyzico iken kullanılır) -->
  <div class="modal hidden" id="payModal" aria-hidden="true">
    <div class="modal-backdrop" id="payBackdrop"></div>
    <div class="modal-panel">
      <div class="modal-head">
        <h3>Ödeme</h3>
        <button class="btn" id="btnPayClose">Kapat</button>
      </div>
      <div class="payment-logos" style="margin-top:10px">
        <span class="pay-logo-iyzico">iyzico</span>
        <span class="pay-logo-sep">ile güvenli ödeme</span>
        <span class="pay-logo-divider"></span>
        <svg class="pay-logo pay-logo-visa" viewBox="0 0 58 20" xmlns="http://www.w3.org/2000/svg"><path d="M23.6 1.3L15.9 18.7h-5.4L6.7 5c-.2-.9-.4-1.2-1.1-1.6C4.4 2.7 2.5 2.2.8 1.8l.1-.5h8.8c1.1 0 2.1.7 2.3 2l2.1 11 5.4-13h4.1zm18.6 11.6c0-4.8-6.6-5-6.6-7.2 0-.6.6-1.3 1.9-1.5.7-.1 2.4-.1 4.4.8l.8-3.4C41.7 1.3 40.3.9 38.6.9c-3.9 0-6.6 2.1-6.7 5 0 2.2 2 3.4 3.5 4.2 1.5.8 2.1 1.2 2.1 1.9 0 1-1.2 1.5-2.3 1.5-2.3 0-3.6-.6-4.6-1.1l-.8 3.5c1.1.5 3 .9 5 .9 4.1 0 6.8-2.1 7.4-3.9zm11.7 5.8h3.6L54.3 1.3h-4c-1 0-1.8.5-2.1 1.4l-6 16.1h4.1l.8-2.3h5.1l.7 2.3zM48.3 13.4l2.1-6 1.3 6h-3.4zM30.4 1.3L27.2 18.7h-4l3.2-17.4h4z" fill="#1A1F71"/></svg>
        <svg class="pay-logo pay-logo-mc" viewBox="0 0 40 25" xmlns="http://www.w3.org/2000/svg"><circle cx="15" cy="12.5" r="9.5" fill="#EB001B"/><circle cx="25" cy="12.5" r="9.5" fill="#F79E1B"/><path d="M20 5.3a9.5 9.5 0 0 1 3.5 7.2 9.5 9.5 0 0 1-3.5 7.2 9.5 9.5 0 0 1-3.5-7.2A9.5 9.5 0 0 1 20 5.3z" fill="#FF5F00"/></svg>
      </div>
      <div class="muted small" id="payPackLine">—</div>

      <div class="grid2" style="margin-top:12px">
        <input class="input" id="payFullName" placeholder="Ad Soyad (opsiyonel)" />
        <input class="input" id="payEmail" placeholder="E-posta (zorunlu)" />
      </div>

      <div class="row" style="margin-top:10px; gap:8px; align-items:center">
        <button class="btn primary" id="btnPayStart">Ödemeyi Başlat</button>
        <button class="btn" id="btnPayRefresh">Krediyi Yenile</button>
        <div class="spacer"></div>
      </div>

      <div class="muted small" id="payRestoreLine" style="margin-top:10px; display:none"></div>

      <div id="iyzicoCheckout" class="iyzico-box" style="margin-top:12px"></div>

      <div class="muted small" style="margin-top:10px">
        Not: Ödeme tamamlandıktan sonra kredi yüklenmesi 5-10 saniye sürebilir.
      </div>
    </div>
  </div>

  <script nonce="<%= cspNonce %>">
    window.__PAYWALL_MODE__ = "<%= paywallMode %>";
    window.__BILLING_MODE__ = "<%= billingMode %>";
    window.__FREE_TRIAL__ = <%= freeTrial %>;
    window.__CHECKOUT_URL__ = "<%= checkoutUrl %>";
    window.__PAYMENTS_PROVIDER__ = "<%= paymentsProvider %>";
    window.__CSP_NONCE__ = "<%= cspNonce %>";
    window.__CHECKOUT_PACKS__ = <%- safeJson(checkoutPacks || []) %>;
    window.APP_META = <%- safeJson(appMeta || {}) %>;
  </script>
  <script src="/public/negotiation-copy.js?v=34"></script>
  <script src="/public/app.js?v=36"></script>
</body>
</html>
