<!doctype html>
<html lang="tr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title><%= appName %></title>
  <meta name="description" content="Sözleşme yükle, risk sinyallerini gör, PDF rapor indir." />
  <meta property="og:title" content="<%= appName %>" />
  <meta property="og:description" content="Sözleşme yükle, riskleri gör, pazarlık metni ve PDF rapor al." />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="<%= baseUrl %>/uygulama" />
  <meta property="og:image" content="<%= baseUrl %>/public/assets/logo.png" />
  <link rel="canonical" href="<%= baseUrl %>/uygulama" />
  <link rel="icon" href="/public/assets/icon.svg" type="image/svg+xml" />
  <link rel="icon" href="/public/assets/icon.png" type="image/png" />
  <link rel="manifest" href="/manifest.webmanifest" />
  <meta name="theme-color" content="#0b1020" />
  <script nonce="<%= cspNonce %>">
  (function(){
    try{
      var k='avukatim_theme';
      var t=localStorage.getItem(k);
      if(t!=='light' && t!=='dark'){
        t = (window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches) ?'light':'dark';
      }
      document.documentElement.setAttribute('data-theme', t);
    }catch(e){}
  })();
</script>
<link rel="stylesheet" href="/public/styles.css?v=17" />
<script src="/public/theme.js?v=17" defer></script>
</head>
<body>
  <header class="topnav">
    <div class="topnav-inner">
        <!-- / ana sayfa bazı kullanıcıları "under construction" sayfasına götürebiliyor.
             Uygulama içinde kalmak için logoyu /uygulama'ya yönlendiriyoruz. -->
        <a class="topnav-brand" href="/uygulama">
        <img class="topnav-icon" src="/public/assets/icon.svg" alt="" />
        <span class="topnav-name"><%= appName %></span>
      </a>
      <nav class="topnav-links">
        <a href="/uygulama">Uygulama</a>
        <a href="/fiyatlandirma">Fiyatlandırma</a>
        <a href="/sss">SSS</a>
      </nav>
      <div class="topnav-actions">
        <% if (billingMode === "credits") { %>
          <div class="credits-pill hidden" id="creditsPill" title="Kalan analiz kredin">Kredi: <span id="creditsCount">—</span></div>
        <% } %>
        <button class="iconbtn" id="themeToggle" type="button" aria-label="Tema değiştir" title="Koyu/Açık tema"></button>
        <button class="btn tiny" id="btnDemo" type="button">Demo</button>
        <button class="btn tiny" id="btnReset" type="button">Sıfırla</button>
      </div>
    </div>
  </header>

  <div class="container">
    <div class="pagehead">
      <div>
        <h1>Sözleşme Analizi <span class="muted small appver">v<%= version %></span></h1>
        <div class="muted">Dosya yükle • risk sinyallerini gör • PDF rapor indir</div>
      </div>
    </div>
    <div id="toast" class="toast hidden" role="status" aria-live="polite"></div>
<div class="card">
      <div class="warnbox">
        <strong>Uyarı:</strong> Bu araç hukuk danışmanlığı değildir. Son karar için avukata danışın.
      </div>

      <div class="grid3">
        <label class="label">
          Rol (skoru etkiler)
          <select id="role" class="select">
            <% roles.forEach(r => { %>
              <option value="<%= r.id %>"><%= r.label %></option>
            <% }) %>
          </select>
        </label>

        <label class="label">
          Sözleşme Türü
          <select id="pack" class="select">
            <option value="genel">Genel</option>
            <option value="hizmet">Hizmet / Freelancer</option>
            <option value="influencer">Influencer Anlaşması</option>
            <option value="etkinlik">Düğün / Etkinlik</option>
            <option value="kira">Kira</option>
            <option value="satis">Alım-Satım</option>
            <option value="saas">SaaS / Üyelik</option>
            <option value="is">İş Sözleşmesi</option>
            <option value="kredi">Kredi / Borç</option>
            <option value="egitim">Eğitim / Kurs</option>
            <option value="gizlilik">Gizlilik / KVKK (NDA)</option>
            <option value="abonelik">Abonelik / Taahhüt (Telefon-İnternet)</option>
            <option value="arac">Araç Kiralama</option>
            <option value="seyahat">Seyahat / Tur / Otel</option>
            <option value="sigorta">Sigorta / Poliçe</option>
          </select>
        </label>

        <label class="label">
          Sözleşme Dosyası (PDF/DOCX/TXT)
          <input type="file" id="file" accept=".pdf,.docx,.txt,application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,text/plain" />
          <div class="muted small">Maksimum dosya boyutu: <%= maxFileMb %> MB</div>
        </label>
      </div>

      <div class="row">
        <div class="muted small" id="fileInfo">Dosya seçilmedi.</div>
        <div class="muted small" id="billingInfo"></div>
        <div class="spacer"></div>
        <button class="btn primary" id="btnAnalyze" disabled>Analiz Et</button>
      <% if (billingMode === "credits") { %>
<div class="billing-box">
  <div class="billing-left">
    <div class="muted small"><strong><%= freeTrial %></strong> ücretsiz analiz sonrası kredi gerekir.</div>
    <% if ((paymentsProvider === "lemonsqueezy" || paymentsProvider === "iyzico") && checkoutPacks && checkoutPacks.length) { %>
      <div class="packs">
        <% checkoutPacks.forEach(p => { %>
          <button class="btn" data-checkout-pack data-credits="<%= p.credits %>"><%= p.label %></button>
        <% }) %>
      </div>
      <% if (paymentsProvider === "iyzico") { %>
      <div class="muted small">Ödeme iyzico üzerinden yapılır. Ödeme tamamlandıktan sonra kredin otomatik yüklenir (bazı durumlarda 5-10 sn sürebilir).</div>
      <div class="muted small">Not: Ödeme için e-posta istenebilir (hesap açmana gerek yok).</div>
    <% } else { %>
      <div class="muted small">Ödeme sonrası kredin otomatik yüklenir (bazı durumlarda 5-10 sn sürebilir).</div>
    <% } %>
    <% } else if (checkoutUrl) { %>
      <a class="btn" href="<%= checkoutUrl %>" target="_blank" rel="noopener">Kredi Satın Al</a>
    <% } else { %>
      <div class="muted small">Satın alma linki için CHECKOUT_URL veya LS_CHECKOUT_PACKS ekleyebilirsin.</div>
    <% } %>
  </div>
  <div class="billing-right">
    <input class="input" id="redeemCode" placeholder="Kredi kodu (örn. AVUKATIM10)" />
    <button class="btn primary" id="btnRedeem">Kodu Aktif Et</button>
    <div class="muted small" style="margin-top:10px">Cihaz değiştirdiysen / çerezler silindiyse:</div>
    <div class="row" style="margin-top:6px; gap:8px; align-items:center">
      <input class="input" id="restoreCode" placeholder="Kurtarma kodu (örn. A8F3-6K2M-P9QD)" />
      <button class="btn" id="btnRestore">Krediyi Kurtar</button>
    </div>

    <div id="lastRestoreBox" class="last-restore hidden">
      <div class="muted small">Kurtarma kodun (sakla): <code id="lastRestoreCode"></code></div>
      <div class="row" style="margin-top:8px; gap:8px; align-items:center">
        <button class="btn tiny" id="btnCopyLastRestore" type="button">Kopyala</button>
        <button class="btn tiny" id="btnClearLastRestore" type="button">Temizle</button>
      </div>
      <div class="muted small" style="margin-top:8px">Bu kod, çerezler silinse bile kredini geri almak içindir. Hesap gerekmez.</div>
    </div>
  </div>
</div>
<% } %>

</div>

    <section class="card hidden" id="resultCard">
      <div class="result-top">
        <div>
          <h2>Sonuç</h2>
        </div>
        <div class="result-actions">
          <% if (paywallMode === "on") { %>
            <input class="input" id="premiumKey" placeholder="Premium anahtarı" />
          <% } %>
          <button class="btn" id="btnPdf" disabled>PDF Rapor İndir</button>
        </div>
      </div>

      <div class="score-grid">
        <div class="score-box">
          <div class="muted small" title="Bu skor, tespit edilen risk türleri ve şiddetine göre hesaplanan yaklaşık bir göstergedir.">Risk Skoru</div>
          <div class="score" id="riskScore">—</div>
          <div class="pill" id="riskLevel">—</div>
        </div>
        <div class="score-box">
          <div class="muted small">Risk Maddeleri</div>
          <div class="score" id="issueCount">—</div>
          <div class="muted small">Tespit edilen net madde sayısı</div>
        </div>
        <div class="score-box">
          <div class="muted small">Belirsizlik / Ek Uyarılar</div>
          <div class="score" id="softCount">—</div>
          <div class="muted small">Eksik/belirsiz alan sinyalleri</div>
        </div>
      </div>

      <!-- Skor Açıklaması kaldırıldı (tekrar eden içerik + daha sade UI) -->

      <div class="top3">
        <h3>En Önemli 3 Risk</h3>
        <div id="top3List" class="list"></div>
      </div>

      <div class="negotiation" id="negBox">
        <div class="neg-head">
          <h3>Pazarlık Çıktısı</h3>
          <div class="muted small">Risklerden otomatik “revize isteği” metni üretir (kopyala-yapıştır). Analizden sonra kendiliğinden oluşur.</div>
        </div>
        <div class="row" style="gap:8px; align-items:center; flex-wrap:wrap">
          <button class="btn" id="btnNegBuild">Yeniden Oluştur</button>
          <button class="btn" id="btnNegCopy" disabled>Kopyala</button>
          <button class="btn" id="btnNegClear">Temizle</button>
          <label class="muted small" style="display:flex; align-items:center; gap:8px; margin-left:auto">
            <input type="checkbox" id="negOnlyFiltered" />
            Sadece ekranda görünen (filtreli) riskleri kullan
          </label>
        </div>
        <textarea id="negText" class="textarea" rows="9" readonly placeholder="Analiz yaptıktan sonra burada otomatik bir pazarlık metni oluşur."></textarea>
        <div class="muted small">İpucu: Her risk kartındaki “Pazarlık Metni” alanı aşağı doğru açılır. İçinden kopyalayabilir veya üstteki kutuya aktarabilirsin.</div>
      </div>


<div class="simulator hidden" id="simCard">
  <h3>Maliyet Simülasyonu</h3>
  <div class="muted small" id="simSummary">—</div>

  <div class="sim-controls">
    <div>
      <div class="muted small">İptal: Davete kaç gün kala?</div>
      <input type="range" id="cancelDays" min="0" max="365" value="60" />
      <div class="muted small" id="cancelDaysVal">—</div>
    </div>

    <div>
      <div class="muted small">Gerçek kişi sayısı</div>
      <input class="input" id="actualGuests" type="number" min="0" step="1" />
	      <input type="range" id="actualGuestsRange" min="0" max="600" value="300" />
	      <div class="muted small" id="actualGuestsVal">—</div>
      <div class="muted small">Garanti kişi sayısını aşarsan ek maliyet doğabilir.</div>
    </div>
  </div>

  <div class="sim-boxes">
    <div class="sim-box">
      <div class="sim-title">İptal Senaryosu</div>
      <div id="cancelResult" class="sim-body">—</div>
    </div>
    <div class="sim-box">
      <div class="sim-title">Kişi Sayısı Senaryosu</div>
      <div id="guestResult" class="sim-body">—</div>
    </div>
  </div>

  <div class="muted small">
    Not: Bu simülasyon sözleşmeden otomatik çıkarım yapar ve yaklaşık değerler üretir. Kesin rakamlar için sözleşme metnini ve tedarikçi ile yazışmalarını esas alın.
  </div>
</div>

      <div class="filters">
        <div class="filter-group">
          <div class="muted small">Seviye</div>
          <div class="chips" id="sevChips"></div>
        </div>
        <div class="filter-group">
          <div class="muted small">Kategori</div>
          <div class="chips" id="catChips"></div>
        </div>
      </div>

      <div class="split">
        <div>
          <h3>Riskler</h3>
          <div id="issueList" class="list"></div>

          <h3>Belirsizlik / Ek Uyarılar</h3>
          <div id="softList" class="list"></div>
        </div>

        <div class="history-col">
          <details class="history-details">
            <summary>Geçmiş (bu cihaz)</summary>
            <div class="muted small" style="margin-top:6px">Bu listede sadece bu cihazda yapılan son analizler görünür.</div>
            <div id="history" class="history"></div>
          </details>
        </div>
      </div>

      <div class="muted small footer-note">
        Bu çıktı bilgilendirme amaçlıdır; hukuki tavsiye değildir.
      </div>
    </section>

    <footer class="footer muted small">
      <a href="/">Ana Sayfa</a> • <a href="/fiyatlandirma">Fiyatlandırma</a> • <a href="/sss">SSS</a> • <a href="/iletisim">İletişim</a> • <a href="/sorumluluk">Sorumluluk Reddi</a> • <a href="/gizlilik">Gizlilik</a> • <a href="/kvkk">KVKK</a> • <a href="/kullanim-sartlari">Kullanım Şartları</a> • <a href="/iade">İade Politikası</a>
      <% if (supportEmail) { %>
        <span> • Destek: <a href="mailto:<%= supportEmail %>"><%= supportEmail %></a></span>
      <% } %>
    </footer>
  </div>



  <!-- iyzico ödeme modalı (PAYMENTS_PROVIDER=iyzico iken kullanılır) -->
  <div class="modal hidden" id="payModal" aria-hidden="true">
    <div class="modal-backdrop" id="payBackdrop"></div>
    <div class="modal-panel">
      <div class="modal-head">
        <h3>Ödeme</h3>
        <button class="btn" id="btnPayClose">Kapat</button>
      </div>
      <div class="muted small" id="payPackLine">—</div>

      <div class="grid2" style="margin-top:12px">
        <input class="input" id="payFullName" placeholder="Ad Soyad (opsiyonel)" />
        <input class="input" id="payEmail" placeholder="E-posta (zorunlu)" />
      </div>

      <div class="row" style="margin-top:10px; gap:8px; align-items:center">
        <button class="btn primary" id="btnPayStart">Ödemeyi Başlat</button>
        <button class="btn" id="btnPayRefresh">Krediyi Yenile</button>
        <div class="spacer"></div>
      </div>

      <div class="muted small" id="payRestoreLine" style="margin-top:10px; display:none"></div>

      <div id="iyzicoCheckout" class="iyzico-box" style="margin-top:12px"></div>

      <div class="muted small" style="margin-top:10px">
        Not: Ödeme tamamlandıktan sonra kredi yüklenmesi 5-10 saniye sürebilir.
      </div>
    </div>
  </div>

  <script nonce="<%= cspNonce %>">
    window.__PAYWALL_MODE__ = "<%= paywallMode %>";
    window.__BILLING_MODE__ = "<%= billingMode %>";
    window.__FREE_TRIAL__ = <%= freeTrial %>;
    window.__CHECKOUT_URL__ = "<%= checkoutUrl %>";
    window.__PAYMENTS_PROVIDER__ = "<%= paymentsProvider %>";
    window.__CSP_NONCE__ = "<%= cspNonce %>";
    window.__CHECKOUT_PACKS__ = <%- JSON.stringify(checkoutPacks || []) %>;
  </script>
  <script src="/public/app.js?v=19"></script>
</body>
</html>
